{
  "version": 2,
  "name": "respirelyf-analytics",
  "builds": [
    { "src": "dashboard/index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/", "dest": "/dashboard/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
